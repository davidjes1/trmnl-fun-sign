{% assign message = trmnl.plugin_settings.custom_fields_values.message | default: "" %}
{% assign subtitle = trmnl.plugin_settings.custom_fields_values.subtitle | default: "" %}
{% assign font_style = trmnl.plugin_settings.custom_fields_values.font_style | default: "classic" %}
{% assign border_style = trmnl.plugin_settings.custom_fields_values.border_style | default: "none" %}
{% assign text_align = trmnl.plugin_settings.custom_fields_values.text_align | default: "center" %}
{% assign sign_theme = trmnl.plugin_settings.custom_fields_values.sign_theme | default: "standard" %}
{% assign show_date = trmnl.plugin_settings.custom_fields_values.show_date | default: "no" %}
{% assign qr_url = trmnl.plugin_settings.custom_fields_values.qr_url | default: "" %}

<div class="layout font--{{ font_style }}">
    {% if sign_theme == "retro" %}
      <div class="fun-sign border--{{ border_style }} theme--retro align--{{ text_align }}">
        <div class="fun-sign__frame">
          <div class="fun-sign__frame-inner">
            {% if message != "" %}
              <div class="fun-sign__message">{{ message }}</div>
              {% if subtitle != "" or show_date == "yes" %}
                <div class="fun-sign__footer">
                  <div class="fun-sign__footer-text">
                    {% if subtitle != "" %}
                      <div class="fun-sign__subtitle">{{ subtitle }}</div>
                    {% endif %}
                    {% if show_date == "yes" %}
                      <div class="fun-sign__datestamp">
                        {% assign now = trmnl.system.timestamp_utc | plus: trmnl.user.utc_offset %}
                        {{ now | date: "%B %-d, %Y" }}
                      </div>
                    {% endif %}
                  </div>
                  {% if qr_url != "" %}
                    <div class="fun-sign__qr">
                      <qr data-url="{{ qr_url }}"></qr>
                    </div>
                  {% endif %}
                </div>
              {% elsif qr_url != "" %}
                <div class="fun-sign__qr">
                  <qr data-url="{{ qr_url }}"></qr>
                </div>
              {% endif %}
            {% else %}
              <div class="fun-sign__message fun-sign__empty">Configure your sign message in plugin settings</div>
            {% endif %}
          </div>
        </div>
      </div>

    {% elsif sign_theme == "notice_board" %}
      <div class="fun-sign border--{{ border_style }} theme--notice_board align--{{ text_align }}">
        <div class="fun-sign__header">Notice</div>
        <div class="fun-sign__content">
          {% if message != "" %}
            <div class="fun-sign__message">{{ message }}</div>
            {% if subtitle != "" or show_date == "yes" %}
              <div class="fun-sign__footer">
                <div class="fun-sign__footer-text">
                  {% if subtitle != "" %}
                    <div class="fun-sign__subtitle">{{ subtitle }}</div>
                  {% endif %}
                  {% if show_date == "yes" %}
                    <div class="fun-sign__datestamp">
                      {% assign now = trmnl.system.timestamp_utc | plus: trmnl.user.utc_offset %}
                      {{ now | date: "%B %-d, %Y" }}
                    </div>
                  {% endif %}
                </div>
                {% if qr_url != "" %}
                  <div class="fun-sign__qr">
                    <qr data-url="{{ qr_url }}"></qr>
                  </div>
                {% endif %}
              </div>
            {% elsif qr_url != "" %}
              <div class="fun-sign__qr">
                <qr data-url="{{ qr_url }}"></qr>
              </div>
            {% endif %}
          {% else %}
            <div class="fun-sign__message fun-sign__empty">Configure your sign message in plugin settings</div>
          {% endif %}
        </div>
      </div>

    {% else %}
      <div class="fun-sign border--{{ border_style }} theme--{{ sign_theme }} align--{{ text_align }}">
        <div class="fun-sign__content">
          {% if message != "" %}
            <div class="fun-sign__message">{{ message }}</div>
            {% if subtitle != "" or show_date == "yes" %}
              <div class="fun-sign__footer">
                <div class="fun-sign__footer-text">
                  {% if subtitle != "" %}
                    <div class="fun-sign__subtitle">{{ subtitle }}</div>
                  {% endif %}
                  {% if show_date == "yes" %}
                    <div class="fun-sign__datestamp">
                      {% assign now = trmnl.system.timestamp_utc | plus: trmnl.user.utc_offset %}
                      {{ now | date: "%B %-d, %Y" }}
                    </div>
                  {% endif %}
                </div>
                {% if qr_url != "" %}
                  <div class="fun-sign__qr">
                    <qr data-url="{{ qr_url }}"></qr>
                  </div>
                {% endif %}
              </div>
            {% elsif qr_url != "" %}
              <div class="fun-sign__qr">
                <qr data-url="{{ qr_url }}"></qr>
              </div>
            {% endif %}
          {% else %}
            <div class="fun-sign__message fun-sign__empty">Configure your sign message in plugin settings</div>
          {% endif %}
        </div>
      </div>
    {% endif %}
</div>
